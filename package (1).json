    "@supabase/auth-helpers-nextjs": "^0.8.0",
    "@supabase/ssr": "^0.1.0",
    "typescript": "^5.3.0",
    "tailwindcss": "^3.4.0",
    "framer-motion": "^10.16.0",
    "zustand": "^4.4.0",
    "@tanstack/react-query": "^5.0.0",
    "zod": "^3.22.0",
    "react-hot-toast": "^2.4.0",
    "lucide-react": "^0.292.0",
    "recharts": "^2.10.0",
